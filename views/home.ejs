<%- include('layouts/header') %>

<section class="hero" style="background: <%= settings.hero_color || '#fde047' %>">
  <h1><%= settings.hero_title || 'Building Hope in Guatemala' %></h1>
  <p class="hero-subtitle"><%= settings.hero_subtitle || "Follow Hannah's journey as she helps build homes and transform lives" %></p>
</section>

<section class="stats-bar">
  <% if (settings.trip_start) { %>
    <div class="stat-item">
      <span class="stat-number" id="days-gone"></span>
      <span class="stat-label">Days in Guatemala</span>
    </div>
  <% } %>
  <div class="stat-item">
    <span class="stat-number"><%= stats.homes_completed || 0 %></span>
    <span class="stat-label">Homes Built</span>
  </div>
  <div class="stat-item">
    <span class="stat-number"><%= stats.groups_hosted || 0 %></span>
    <span class="stat-label">Groups Hosted</span>
  </div>
  <div class="stat-item">
    <span class="stat-number"><%= stats.families_served || 0 %></span>
    <span class="stat-label">Families Served</span>
  </div>
  <% if (settings.trip_end) { %>
    <div class="stat-item">
      <span class="stat-number" id="days-left"></span>
      <span class="stat-label" id="days-left-label">Days Until Home</span>
    </div>
  <% } %>
</section>

<% if (settings.trip_start || settings.trip_end) { %>
<script>
  (function() {
    const now = new Date();
    now.setHours(0,0,0,0);

    <% if (settings.trip_start) { %>
    const start = new Date('<%= settings.trip_start %>');
    start.setHours(0,0,0,0);
    const gone = Math.max(0, Math.ceil((now - start) / 86400000));
    const el = document.getElementById('days-gone');
    if (el) el.textContent = gone;
    <% } %>

    <% if (settings.trip_end) { %>
    const end = new Date('<%= settings.trip_end %>');
    end.setHours(0,0,0,0);
    const left = Math.ceil((end - now) / 86400000);
    const leftEl = document.getElementById('days-left');
    const labelEl = document.getElementById('days-left-label');
    if (leftEl) {
      if (left > 0) {
        leftEl.textContent = left;
      } else {
        leftEl.textContent = '0';
        if (labelEl) labelEl.textContent = "She's Home!";
      }
    }
    <% } %>
  })();
</script>
<% } %>

<section class="section">
  <h2>Latest Updates</h2>
  <% if (posts.length === 0) { %>
    <p class="empty-state">No posts yet — check back soon!</p>
  <% } %>
  <div class="post-grid">
    <% posts.forEach(post => { %>
      <article class="post-card">
        <% if (post.featured_image) { %>
          <div class="post-card-image">
            <img src="/uploads/<%= post.featured_image %>" alt="<%= post.title %>" loading="lazy">
          </div>
        <% } %>
        <div class="post-card-body">
          <span class="post-category category-<%= post.category %>"><%= post.category %></span>
          <h3><a href="/post/<%= post.slug %>"><%= post.title %></a></h3>
          <p class="post-excerpt"><%= post.excerpt || post.content.substring(0, 150) + '...' %></p>
          <div class="post-meta">
            <time><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></time>
            <% if (post.comment_count > 0) { %>
              <span><%= post.comment_count %> comment<%= post.comment_count !== 1 ? 's' : '' %></span>
            <% } %>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<% if (recentPrayers.length > 0) { %>
<section class="section">
  <h2>Recent Prayer Requests</h2>
  <div class="prayer-list">
    <% recentPrayers.forEach(prayer => { %>
      <div class="prayer-card">
        <p>"<%= prayer.content %>"</p>
        <span class="prayer-author">- <%= prayer.author_name %></span>
      </div>
    <% }) %>
  </div>
  <a href="/prayers" class="btn btn-outline">View All Prayer Requests</a>
</section>
<% } %>

<section class="section subscribe-section">
  <h2>Stay Updated</h2>
  <p class="section-intro">Get an email whenever Hannah posts a new update.</p>
  <form class="subscribe-form" action="/subscribe" method="POST">
    <div class="form-row">
      <div class="form-group">
        <input type="text" name="name" placeholder="Your Name" required>
      </div>
      <div class="form-group">
        <input type="email" name="email" placeholder="Your Email" required>
      </div>
      <button type="submit" class="btn">Subscribe</button>
    </div>
  </form>
  <p class="form-note">You'll receive a confirmation email. Unsubscribe anytime.</p>
</section>

<%- include('layouts/footer') %>
