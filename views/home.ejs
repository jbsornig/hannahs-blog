<%- include('layouts/header') %>

<section class="hero">
  <h1>Building Hope in Guatemala</h1>
  <p class="hero-subtitle">Follow Hannah's journey as she helps build homes and transform lives</p>
</section>

<section class="stats-bar">
  <div class="stat-item">
    <span class="stat-number"><%= stats.homes_completed || 0 %></span>
    <span class="stat-label">Homes Built</span>
  </div>
  <div class="stat-item">
    <span class="stat-number"><%= stats.groups_hosted || 0 %></span>
    <span class="stat-label">Groups Hosted</span>
  </div>
  <div class="stat-item">
    <span class="stat-number"><%= stats.families_served || 0 %></span>
    <span class="stat-label">Families Served</span>
  </div>
</section>

<section class="section">
  <h2>Latest Updates</h2>
  <% if (posts.length === 0) { %>
    <p class="empty-state">No posts yet — check back soon!</p>
  <% } %>
  <div class="post-grid">
    <% posts.forEach(post => { %>
      <article class="post-card">
        <% if (post.featured_image) { %>
          <div class="post-card-image">
            <img src="/uploads/<%= post.featured_image %>" alt="<%= post.title %>" loading="lazy">
          </div>
        <% } %>
        <div class="post-card-body">
          <span class="post-category category-<%= post.category %>"><%= post.category %></span>
          <h3><a href="/post/<%= post.slug %>"><%= post.title %></a></h3>
          <p class="post-excerpt"><%= post.excerpt || post.content.substring(0, 150) + '...' %></p>
          <div class="post-meta">
            <time><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></time>
            <% if (post.comment_count > 0) { %>
              <span><%= post.comment_count %> comment<%= post.comment_count !== 1 ? 's' : '' %></span>
            <% } %>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<% if (recentPrayers.length > 0) { %>
<section class="section">
  <h2>Recent Prayer Requests</h2>
  <div class="prayer-list">
    <% recentPrayers.forEach(prayer => { %>
      <div class="prayer-card">
        <p>"<%= prayer.content %>"</p>
        <span class="prayer-author">- <%= prayer.author_name %></span>
      </div>
    <% }) %>
  </div>
  <a href="/prayers" class="btn btn-outline">View All Prayer Requests</a>
</section>
<% } %>

<%- include('layouts/footer') %>
