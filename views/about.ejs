<%- include('layouts/header') %>

<section class="section about-page">
  <h1>About This Mission</h1>

  <div class="about-content">
    <div class="post-content"><%= aboutContent %></div>

    <h2>How You Can Help</h2>
    <ul>
      <li>Pray for the mission, the teams, and the families</li>
      <li>Submit a <a href="/prayers">prayer request</a></li>
      <li>Follow along and leave encouraging <a href="/posts">comments</a></li>
      <li>Share this blog with others</li>
    </ul>

    <div class="stats-bar">
      <div class="stat-item">
        <span class="stat-number"><%= stats.homes_completed || 0 %></span>
        <span class="stat-label">Homes Built</span>
      </div>
      <div class="stat-item">
        <span class="stat-number"><%= stats.groups_hosted || 0 %></span>
        <span class="stat-label">Groups Hosted</span>
      </div>
      <div class="stat-item">
        <span class="stat-number"><%= stats.families_served || 0 %></span>
        <span class="stat-label">Families Served</span>
      </div>
    </div>
  </div>
</section>

<%- include('layouts/footer') %>
