<%- include('../layouts/header') %>

<section class="section">
  <h1><%= post ? 'Edit Post' : 'New Post' %></h1>

  <form action="/admin/posts/save" method="POST" enctype="multipart/form-data" class="post-form">
    <% if (post) { %>
      <input type="hidden" name="id" value="<%= post.id %>">
    <% } %>

    <div class="form-group">
      <label for="title">Title *</label>
      <input type="text" id="title" name="title" value="<%= post ? post.title : '' %>" required>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="update" <%= post && post.category === 'update' ? 'selected' : '' %>>Update</option>
          <option value="build-report" <%= post && post.category === 'build-report' ? 'selected' : '' %>>Build Report</option>
          <option value="prayer" <%= post && post.category === 'prayer' ? 'selected' : '' %>>Prayer</option>
          <option value="photos" <%= post && post.category === 'photos' ? 'selected' : '' %>>Photos</option>
        </select>
      </div>
      <div class="form-group">
        <label class="checkbox-label">
          <input type="checkbox" name="published" value="1" <%= (!post || post.published) ? 'checked' : '' %>>
          Publish immediately
        </label>
      </div>
    </div>

    <div class="form-group">
      <label for="excerpt">Short Description (shown in previews)</label>
      <input type="text" id="excerpt" name="excerpt" value="<%= post ? (post.excerpt || '') : '' %>"
        placeholder="Brief summary of this post...">
    </div>

    <div class="form-group">
      <label for="content">Content *</label>
      <textarea id="content" name="content" rows="12" required><%= post ? post.content : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="photos">Add Photos</label>
      <input type="file" id="photos" name="photos" multiple accept="image/*">
      <p class="form-note">Photos will be auto-compressed for fast loading. You can select multiple.</p>
    </div>

    <% if (post && typeof images !== 'undefined' && images && images.length > 0) { %>
      <div class="form-group">
        <label>Current Photos</label>
        <div class="image-preview-grid">
          <% images.forEach(img => { %>
            <div class="image-preview">
              <img src="/uploads/<%= img.filename %>" alt="">
              <form action="/admin/images/<%= img.id %>/delete" method="POST">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Remove this photo?')">Remove</button>
              </form>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="form-group">
      <label for="videos">Add Videos</label>
      <input type="file" id="videos" name="videos" multiple accept="video/mp4,video/quicktime,video/webm,.mp4,.mov,.webm">
      <p class="form-note">Max 50MB per video. MP4, MOV, and WebM supported.</p>
    </div>

    <% if (post && typeof videos !== 'undefined' && videos && videos.length > 0) { %>
      <div class="form-group">
        <label>Current Videos</label>
        <div class="image-preview-grid">
          <% videos.forEach(vid => { %>
            <div class="image-preview">
              <video src="/uploads/<%= vid.filename %>" style="height:80px; width:100%; object-fit:cover;"></video>
              <form action="/admin/videos/<%= vid.id %>/delete" method="POST">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Remove this video?')">Remove</button>
              </form>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="form-actions">
      <button type="submit" class="btn">Save Post</button>
      <a href="/admin" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</section>

<%- include('../layouts/footer') %>
