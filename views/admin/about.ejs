<%- include('../layouts/header') %>

<section class="section">
  <div class="admin-header">
    <h1>Edit Site Content</h1>
    <a href="/admin" class="btn btn-outline">Back to Dashboard</a>
  </div>

  <form action="/admin/about" method="POST">
    <div class="admin-section">
      <h2>Site Name</h2>
      <div class="form-group">
        <label for="site_name">Blog Name (shown in header and browser tab)</label>
        <input type="text" id="site_name" name="site_name" value="<%= settings.site_name || '' %>" placeholder="Hannah's Blog">
      </div>
    </div>

    <div class="admin-section">
      <h2>Homepage Header</h2>
      <div class="form-group">
        <label for="hero_title">Main Heading</label>
        <input type="text" id="hero_title" name="hero_title" value="<%= settings.hero_title || '' %>" placeholder="Building Hope in Guatemala">
      </div>
      <div class="form-group">
        <label for="hero_subtitle">Subtitle</label>
        <input type="text" id="hero_subtitle" name="hero_subtitle" value="<%= settings.hero_subtitle || '' %>" placeholder="Follow Hannah's journey...">
      </div>
      <div class="form-group">
        <label for="hero_color">Background Color</label>
        <input type="color" id="hero_color" name="hero_color" value="<%= settings.hero_color || '#fde047' %>" style="width:60px;height:36px;padding:2px;cursor:pointer;">
      </div>
    </div>

    <div class="admin-section">
      <h2>About Page</h2>
      <div class="form-group">
        <label for="about_content">About Page Content</label>
        <textarea id="about_content" name="about_content" rows="15"><%= settings.about_content || '' %></textarea>
        <p class="form-note">Write in plain text. Blank lines will create paragraph breaks.</p>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn">Save All</button>
      <a href="/" class="btn btn-outline" target="_blank">Preview Homepage</a>
      <a href="/about" class="btn btn-outline" target="_blank">Preview About</a>
    </div>
  </form>
</section>

<%- include('../layouts/footer') %>
