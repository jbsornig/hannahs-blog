<%- include('../layouts/header') %>

<section class="section">
  <div class="admin-header">
    <h1>Edit About Page</h1>
    <a href="/admin" class="btn btn-outline">Back to Dashboard</a>
  </div>

  <form action="/admin/about" method="POST">
    <div class="form-group">
      <label for="about_content">About Page Content</label>
      <textarea id="about_content" name="about_content" rows="15"><%= aboutContent %></textarea>
      <p class="form-note">Write in plain text. Blank lines will create paragraph breaks.</p>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn">Save</button>
      <a href="/about" class="btn btn-outline" target="_blank">Preview Current Page</a>
    </div>
  </form>
</section>

<%- include('../layouts/footer') %>
