      <a href="/" class="nav-brand"><%= siteName %></a>
      <button class="nav-toggle" aria-label="Toggle menu">&#9776;</button>
      <div class="nav-links">
        <a href="/" class="<%= page === 'home' ? 'active' : '' %>">Home</a>
        <a href="/posts" class="<%= page === 'posts' ? 'active' : '' %>">Posts</a>
        <a href="/prayers" class="<%= page === 'prayers' ? 'active' : '' %>">Prayer Requests</a>
